generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id          String     @id @default(cuid())
  name        String
  description String?
  discipline  String     @default("General")
  // Lightweight per-browser isolation: which browser owns this project.
  // null = legacy project created before this feature (claimable on first load).
  ownerId     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  documents   Document[]
  chatMessages ChatMessage[]
  annotations Annotation[]
  outputs     GeneratedOutput[]
  notes       Note[]

  @@index([ownerId])
}

model Document {
  id           String     @id @default(cuid())
  projectId    String
  filename     String
  fileType     String     // pdf, docx, txt, xlsx, csv
  fileSize     Int
  filePath     String
  discipline   String     @default("General")
  uploadedAt   DateTime   @default(now())
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chunks       DocumentChunk[]
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  chunkIndex Int
  pageNumber Int?
  text       String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  projectId String
  role      String   // user, assistant
  content   String
  citations String?  // JSON array of citations
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Annotation {
  id         String   @id @default(cuid())
  documentId String
  projectId  String
  pageNumber Int?
  selectedText String
  note       String?
  color      String   @default("#FFEB3B")
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model GeneratedOutput {
  id         String   @id @default(cuid())
  projectId  String
  outputType String   // commissioning_checklist, equipment_schedule, handover_report, data_extraction
  title      String
  content    String
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// Pinned notes — saved AI answers the user wants to keep (NotebookLM-style notes)
model Note {
  id        String   @id @default(cuid())
  projectId String
  title     String
  content   String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// Singleton row storing the user's AI provider configuration.
/// id is always "singleton".
model Setting {
  id        String  @id @default("singleton")
  provider  String  @default("gemini")   // "gemini" | "openai" | "anthropic"
  model     String  @default("gemini-2.5-flash")
  apiKey    String  @default("")          // user-supplied key (stored in DB)
  baseUrl   String?                       // optional override (OpenAI-compatible providers)
  updatedAt DateTime @updatedAt
}